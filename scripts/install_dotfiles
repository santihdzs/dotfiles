#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OS="$(scripts/helpers/os_detect)"
BACKUP_DIR="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"

stow_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  # each subdirectory is a stow package
  local pkgs
  pkgs="$(find "$dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort || true)"

  [[ -z "$pkgs" ]] && return 0

  while read -r pkg; do
    [[ -z "$pkg" ]] && continue
    echo "[install_dotfiles] -> $pkg (from $dir)"

    # backup conflicts: if target exists and is not a symlink, move it out
    (cd "$dir/$pkg" && find . -mindepth 1 -print) | while read -r rel; do
      rel="${rel#./}"
      target="$HOME/$rel"

      if [[ -e "$target" && ! -L "$target" ]]; then
        mkdir -p "$BACKUP_DIR/$(dirname "$rel")"
        mv "$target" "$BACKUP_DIR/$rel"
      fi
    done

    stow -d "$dir" -t "$HOME" "$pkg"
  done <<< "$pkgs"
}

echo "[install_dotfiles] OS=$OS"
echo "[install_dotfiles] Backup dir: $BACKUP_DIR"
cd "$ROOT"

stow_dir "$ROOT/stow/common"
if [[ "$OS" == "arch" ]]; then
  stow_dir "$ROOT/stow/arch"
elif [[ "$OS" == "mac" ]]; then
  stow_dir "$ROOT/stow/mac"
fi

echo "[install_dotfiles] Done."
