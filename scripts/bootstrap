#!/usr/bin/env bash
set -euo pipefail

ROOT="${ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
OS="$("$ROOT/scripts/helpers/os_detect")"

echo "[bootstrap] OS=$OS"

# antidote
if [[ ! -d "$HOME/.antidote" ]]; then
  echo "[bootstrap] Installing antidote..."
  git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
else
  echo "[bootstrap] antidote already installed"
fi

# tmux (gpakosz/.tmux)
if [[ ! -d "$HOME/.tmux" ]]; then
  echo "[bootstrap] Installing tmux config..."
  git clone https://github.com/gpakosz/.tmux.git "$HOME/.tmux"
  ln -sf "$HOME/.tmux/.tmux.conf" "$HOME/.tmux.conf"
else
  echo "[bootstrap] tmux config already installed"
fi

# bun (requires unzip)
if [[ ! -d "$HOME/.bun" ]]; then
  echo "[bootstrap] Installing bun..."
  if ! command -v unzip >/dev/null 2>&1; then
    echo "[bootstrap] Installing unzip (bun dependency)..."
    sudo pacman -S --needed --noconfirm unzip
  fi
  curl -fsSL https://bun.sh/install | bash
else
  echo "[bootstrap] bun already installed"
fi

echo "[bootstrap] Done."
